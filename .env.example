# AskNow third-party integration configuration
#
# Copy this file to `.env` and fill only the services you use.
# Internal AskNow runtime settings are intentionally ignored in `.env`.

# AI participation assistant: DeepSeek through LiteLLM
DEEPSEEK_API_KEY=

# Speaker diarization: Pyannote gated Hugging Face models
HUGGINGFACE_API_KEY=

# Live microphone: Volcengine Doubao
VOLCENGINE_APP_ID=
VOLCENGINE_ACCESS_TOKEN=
VOLCENGINE_RESOURCE_ID=volc.bigasr.sauc.duration

# Optional remote model API gateway
MODEL_API_BASE_URL=
MODEL_API_KEY=
TRANSCRIPTION_API_BASE_URL=
TRANSCRIPTION_API_KEY=
DIARIZATION_API_BASE_URL=
DIARIZATION_API_KEY=
STREAM_API_BASE_URL=
STREAM_API_KEY=
