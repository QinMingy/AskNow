# AskNow local configuration
#
# Copy this file to `.env` and fill only the providers you use.
# Existing process/system environment variables take precedence over `.env`.

# AI participation assistant: DeepSeek through LiteLLM
DEEPSEEK_API_KEY=

# Speaker diarization: Pyannote gated Hugging Face models
HUGGINGFACE_API_KEY=
# Optional Hugging Face download resilience
# HF_HUB_DOWNLOAD_TIMEOUT=120
# DIARIZATION_LOAD_MAX_ATTEMPTS=3
# DIARIZATION_LOAD_RETRY_BACKOFF_SECONDS=2

# Live microphone: Volcengine Doubao streaming ASR
# STREAM_PROCESSOR=volcengine
VOLCENGINE_APP_ID=
VOLCENGINE_ACCESS_TOKEN=
VOLCENGINE_RESOURCE_ID=volc.bigasr.sauc.duration

# Optional remote model API fallback
# MODEL_API_BASE_URL=https://models.example.com
# MODEL_API_KEY=

# Provider selection examples
# TRANSCRIPTION_PROVIDER=local
# DIARIZATION_PROVIDER=pyannote
# STREAM_PROCESSOR=funasr
# ASSIST_PROVIDER=litellm
